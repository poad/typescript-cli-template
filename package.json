    "lint-fix": "eslint --fix",
    "package": "echo Skip the packaging process",
    "all": "pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^25.6.0",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.3.0",
    "jiti": "^2.7.0",
    "pnpm": "^10.33.4",
    "regenerator-runtime": "^0.14.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
